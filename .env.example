# Required environment variables

# Google Cloud TTS API key (free tier: 1M WaveNet characters/month)
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable the "Cloud Text-to-Speech API" in your GCP project first.
GOOGLE_TTS_API_KEY=your_api_key_here

# Anthropic Claude API key (for AI lesson generation)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Spotify integration (optional — for background yoga music)
# 1. Create a free app at https://developer.spotify.com/dashboard
# 2. Under "Edit Settings", add redirect URI: http://localhost:8888/callback
# 3. Copy Client ID and Client Secret below
# Requires Spotify Premium for playback control via API.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
